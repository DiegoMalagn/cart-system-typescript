{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://cart-system-typescript-production.up.railway.app/api/$1"
    },
    {
      "source": "/checkout",
      "destination": "https://cart-system-typescript-production.up.railway.app/checkout"
    },
    {
      "source": "/webhook",
      "destination": "https://cart-system-typescript-production.up.railway.app/webhook"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
